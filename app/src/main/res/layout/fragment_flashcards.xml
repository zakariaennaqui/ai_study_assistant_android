<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:padding="@dimen/spacing_md"
    android:gravity="center">

    <!-- Counter -->
    <TextView
        android:id="@+id/tv_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/color_on_surface_muted"
        android:textSize="14sp"
        android:text="1 / 10"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- Flip card container (FrameLayout for front/back overlay) -->
    <FrameLayout
        android:id="@+id/fl_card"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <!-- Front face -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_front"
            style="@style/Widget.App.Card.Feature"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/color_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flashcard_front"
                    android:textColor="@color/color_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tv_front"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_on_background"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Back face (rotated 180 to start, becomes visible after flip) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_back"
            style="@style/Widget.App.Card.Feature"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:rotationY="180"
            app:cardBackgroundColor="@color/color_card_elevated">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flashcard_back"
                    android:textColor="@color/color_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tv_back"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_on_background"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Tap hint -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/flashcard_tap_hint"
        android:textColor="@color/color_on_surface_muted"
        android:textSize="13sp"
        android:layout_marginBottom="@dimen/spacing_xl" />

    <!-- Prev / Next navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev"
            style="@style/Widget.App.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="‹ Prev" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Next ›" />
    </LinearLayout>

</LinearLayout>
