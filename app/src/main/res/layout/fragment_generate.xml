<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/generate_title"
            android:textColor="@color/color_on_background"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingTop="24dp"
            android:paddingBottom="20dp" />

        <!-- Type selector label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_type"
            android:textColor="@color/color_on_surface_muted"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_summary"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chip_summary"
                android:textColor="@color/chip_generate_text"
                app:chipBackgroundColor="@color/chip_generate_fill"
                app:chipStrokeColor="@color/color_stroke"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="10dp"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_quiz"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chip_quiz"
                android:textColor="@color/chip_generate_text"
                app:chipBackgroundColor="@color/chip_generate_fill"
                app:chipStrokeColor="@color/color_stroke"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="10dp"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_flashcards"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chip_flashcards"
                android:textColor="@color/chip_generate_text"
                app:chipBackgroundColor="@color/chip_generate_fill"
                app:chipStrokeColor="@color/color_stroke"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="10dp"
                app:checkedIconVisible="false" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Summary: how much detail -->
        <LinearLayout
            android:id="@+id/panel_summary_depth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_summary_depth"
                android:textColor="@color/color_on_surface_muted"
                android:textSize="13sp"
                android:paddingBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_summary_depth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_depth_essentials"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summary_depth_essentials"
                    android:textColor="@color/chip_generate_text"
                    app:chipBackgroundColor="@color/chip_generate_fill"
                    app:chipStrokeColor="@color/color_stroke"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="10dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_depth_balanced"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summary_depth_balanced"
                    android:textColor="@color/chip_generate_text"
                    app:chipBackgroundColor="@color/chip_generate_fill"
                    app:chipStrokeColor="@color/color_stroke"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="10dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_depth_thorough"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summary_depth_thorough"
                    android:textColor="@color/chip_generate_text"
                    app:chipBackgroundColor="@color/chip_generate_fill"
                    app:chipStrokeColor="@color/color_stroke"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="10dp"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- Quiz: number of questions -->
        <LinearLayout
            android:id="@+id/panel_quiz_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_quiz_question_count"
                android:textColor="@color/color_on_surface_muted"
                android:textSize="13sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tv_quiz_count_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_background"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <SeekBar
                android:id="@+id/seek_quiz_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="9"
                android:progress="2"
                android:minHeight="36dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:thumbTint="@color/color_primary"
                android:progressTint="@color/color_primary"
                android:progressBackgroundTint="@color/color_stroke" />
        </LinearLayout>

        <!-- Subject -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_subject"
            style="@style/Widget.App.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_subject"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_subject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:textColor="@color/color_on_background"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@color/color_card_elevated"
            app:tabTextColor="@color/tab_generate_text"
            app:tabIndicatorColor="@color/color_primary"
            app:tabIndicatorHeight="2dp"
            app:tabRippleColor="@color/color_primary_soft"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/generate_tab_text" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/generate_tab_image" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Text input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_text"
            style="@style/Widget.App.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_text_input"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="6"
                android:maxLines="12"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="@color/color_on_background"
                android:scrollbars="vertical" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Image panel -->
        <LinearLayout
            android:id="@+id/panel_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_camera"
                    style="@style/Widget.App.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_camera" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_gallery"
                    style="@style/Widget.App.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_gallery" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_image_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/color_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iv_preview"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:contentDescription="Selected image" />

                    <TextView
                        android:id="@+id/tv_ocr_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ocr_scanning"
                        android:textColor="@color/color_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Char count -->
        <TextView
            android:id="@+id/tv_char_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_on_surface_muted"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginBottom="12dp"
            android:text="0 / 20000" />

        <!-- Error -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_error"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:padding="10dp"
            android:background="@color/color_error_soft"
            android:layout_marginBottom="8dp" />

        <!-- Generate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_generate" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:indeterminate="true"
            app:indicatorColor="@color/color_primary"
            app:trackColor="@color/color_stroke"
            app:trackCornerRadius="2dp" />

        <TextView
            android:id="@+id/tv_generating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/generating"
            android:textColor="@color/color_on_surface_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
